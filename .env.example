# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret
AUTH_SECRET=replace_with_a_long_random_secret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zendo

# Cloudflare R2 (S3 API)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=zendo-media

# Public media domain (custom domain mapped to R2 bucket)
R2_PUBLIC_BASE_URL=https://media.zendo.vn
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://media.zendo.vn

# Internal cron (cleanup jobs) — Bearer token for GET/POST /api/internal/cleanup/*
INTERNAL_CRON_SECRET=

# Affiliate CCCD draft cleanup (prefix private/affiliate-payout-change-drafts/)
AFFILIATE_PAYOUT_DRAFT_ORPHAN_TTL_HOURS=72
AFFILIATE_PAYOUT_REJECTED_MEDIA_RETENTION_DAYS=14
AFFILIATE_PAYOUT_DRAFT_CLEANUP_LIST_PAGE_SIZE=500
# AFFILIATE_PAYOUT_DRAFT_CLEANUP_DRY_RUN=true

# Optional social auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pusher (realtime chat /chat — optional; thiếu thì chat vẫn lưu DB, không push tức thì)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Optional: admin id dùng làm người gửi tin auto-reply (thiếu thì dùng admin ACTIVE đầu tiên trong DB)
SUPPORT_AUTO_REPLY_ADMIN_ID=
